<?xml version="1.0"?>
<robot name="foldable_box_small">

  <material name="box_base_color">
    <color rgba="0.8 0.5 0.2 1"/>
  </material>
  <material name="box_flap_color">
    <color rgba="0.9 0.7 0.4 1"/>
  </material>

  <!-- ================= Base link ================= -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="20"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- 0.30,0.24,0.20 * 0.7 -->
        <box size="0.21 0.168 0.14"/>
      </geometry>
      <material name="box_base_color"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.21 0.168 0.14"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= +X flap ================= -->
  <link name="flap_px">
    <inertial>
      <origin xyz="0.042 0 -0.0035" rpy="0 0 0"/>
      <mass value="0.006"/>
      <inertia ixx="0.00015" iyy="0.00015" izz="0.00015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0.042 0 -0.0035" rpy="0 0 0"/>
      <geometry>
        <!-- 0.12,0.24,0.01 * 0.7 -->
        <box size="0.084 0.168 0.007"/>
      </geometry>
      <material name="box_flap_color"/>
    </visual>

    <collision>
      <origin xyz="0.042 0 -0.0035" rpy="0 0 0"/>
      <geometry>
        <box size="0.084 0.168 0.007"/>
      </geometry>
    </collision>
  </link>

  <joint name="flap_px_joint" type="revolute">
    <parent link="base_link"/>
    <child link="flap_px"/>
    <!-- 0.15,0,0.10 * 0.7 -->
    <origin xyz="0.105 0 0.07" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="3" velocity="5" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- ================= -X flap ================= -->
  <link name="flap_nx">
    <inertial>
      <origin xyz="-0.042 0 -0.0035" rpy="0 0 0"/>
      <mass value="0.006"/>
      <inertia ixx="0.00015" iyy="0.00015" izz="0.00015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="-0.042 0 -0.0035" rpy="0 0 0"/>
      <geometry>
        <box size="0.084 0.168 0.007"/>
      </geometry>
      <material name="box_flap_color"/>
    </visual>

    <collision>
      <origin xyz="-0.042 0 -0.0035" rpy="0 0 0"/>
      <geometry>
        <box size="0.084 0.168 0.007"/>
      </geometry>
    </collision>
  </link>

  <joint name="flap_nx_joint" type="revolute">
    <parent link="base_link"/>
    <child link="flap_nx"/>
    <origin xyz="-0.105 0 0.07" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="3" velocity="5" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- ================= +Y flap ================= -->
  <link name="flap_py">
    <inertial>
      <origin xyz="0 0.042 -0.0035" rpy="0 0 0"/>
      <mass value="0.006"/>
      <inertia ixx="0.00015" iyy="0.00015" izz="0.00015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0.042 -0.0035" rpy="0 0 0"/>
      <geometry>
        <!-- 0.30,0.12,0.01 * 0.7 -->
        <box size="0.21 0.084 0.007"/>
      </geometry>
      <material name="box_flap_color"/>
    </visual>

    <collision>
      <origin xyz="0 0.042 -0.0035" rpy="0 0 0"/>
      <geometry>
        <box size="0.21 0.084 0.007"/>
      </geometry>
    </collision>
  </link>

  <joint name="flap_py_joint" type="revolute">
    <parent link="base_link"/>
    <child link="flap_py"/>
    <origin xyz="0 0.084 0.07" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit effort="3" velocity="5" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- ================= -Y flap ================= -->
  <link name="flap_ny">
    <inertial>
      <origin xyz="0 -0.042 -0.0035" rpy="0 0 0"/>
      <mass value="0.006"/>
      <inertia ixx="0.00015" iyy="0.00015" izz="0.00015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 -0.042 -0.0035" rpy="0 0 0"/>
      <geometry>
        <box size="0.21 0.084 0.007"/>
      </geometry>
      <material name="box_flap_color"/>
    </visual>

    <collision>
      <origin xyz="0 -0.042 -0.0035" rpy="0 0 0"/>
      <geometry>
        <box size="0.21 0.084 0.007"/>
      </geometry>
    </collision>
  </link>

  <joint name="flap_ny_joint" type="revolute">
    <parent link="base_link"/>
    <child link="flap_ny"/>
    <origin xyz="0 -0.084 0.07" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="3" velocity="5" lower="-3.14" upper="3.14"/>
  </joint>

</robot>
